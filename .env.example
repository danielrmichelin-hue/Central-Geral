# ─────────────────────────────────────────────────────────────
# Central Geral — variáveis de ambiente
# Copie este arquivo para ".env" e preencha com as chaves do seu
# projeto Supabase. SEM elas, o app roda em MODO DEMO (localStorage).
# ─────────────────────────────────────────────────────────────

# Supabase → Project Settings → API → Project URL
VITE_SUPABASE_URL=

# Supabase → Project Settings → API → Project API keys → anon / public
VITE_SUPABASE_ANON_KEY=
